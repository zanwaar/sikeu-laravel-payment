# ============================================================================
# SIKEU Payment API Configuration
# ============================================================================
# Add these lines to your Laravel .env file

# API Endpoints
SIKEU_API_BASE_URL=http://localhost:8080
SIKEU_API_ENDPOINT=/api/payment-requests
SIKEU_API_TIMEOUT=30

# Authentication Credentials
# Get these from SIKEU administrator
SIKEU_API_KEY=
SIKEU_SHARED_SECRET=

# Timestamp Tolerance (in seconds)
SIKEU_TIMESTAMP_TOLERANCE=300

# Source Application Name
# This should match your registered app name in SIKEU
SIKEU_SOURCE_APP=SIAKAD

# Payment Gateway Provider
# Options: BRI, MANDIRI
SIKEU_DEFAULT_PROVIDER=BRI

# Logging Configuration
SIKEU_LOGGING_ENABLED=true
SIKEU_LOG_CHANNEL=daily
