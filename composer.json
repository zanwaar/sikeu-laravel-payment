{
    "name": "sikeu/laravel-payment",
    "description": "SIKEU Payment Gateway integration package for Laravel - supporting multiple payment with Virtual Account and QRIS",
    "keywords": ["laravel", "payment", "gateway", "sikeu", "virtual-account", "qris", "indonesia"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "SIKEU Development Team",
            "email": "zanwaarsamjid@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "suggest": {
        "endroid/qr-code": "Untuk render qrContent string menjadi gambar QR PNG/SVG (^4.0|^5.0)",
        "simplesoftwareio/simple-qrcode": "Alternatif QR renderer untuk Laravel Blade (^4.0)"
    },
    "autoload": {
        "psr-4": {
            "Sikeu\\LaravelPayment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sikeu\\LaravelPayment\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sikeu\\LaravelPayment\\SikeuPaymentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
